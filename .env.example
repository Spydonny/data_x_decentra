# Root reference file for the full repository.
# Copy backend values into `kya-backend/.env`.

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
SOLANA_RPC_URL=https://api.devnet.solana.com
# JSON array exported from a Solana keypair, for example [1,2,3,...]
SOLANA_PRIVATE_KEY=[1,2,3]
KYA_KEYPAIR_PATH=
KYA_PROGRAM_ID=3HtY7pQE8pcsjJ2BxhadeSg7ZoU7Hm28pgMRYCpj5n4g
KYA_IDL_PATH=./kya-backend/idl/kya_program.json
KYA_LOGGER_AUTHORITY=
KYA_LOGGER_PRIVATE_KEY=
KYA_LOGGER_KEYPAIR_PATH=
KYA_MCP_API_KEYS=local-dev-key
ELIZA_API_URL=
ELIZA_API_KEY=
KYA_MCP_SSE_URL=http://localhost:8000/mcp/sse
KYA_MCP_API_KEY=local-dev-key

# Copy frontend values into `kya_front/.env`.
VITE_KYA_API_URL=http://localhost:8000
